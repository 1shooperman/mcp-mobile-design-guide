{
  "name": "mcp-mobile-design-guide",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "ingest": "tsx src/ingest.ts",
    "test": "jest",
    "lint": "biome check",
    "validate": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1shooperman/mcp-mobile-design-guide.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/1shooperman/mcp-mobile-design-guide/issues"
  },
  "homepage": "https://github.com/1shooperman/mcp-mobile-design-guide#readme",
  "description": "",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fastmcp": "^4.0.1",
    "sqlite-vec": "^0.1.9",
    "voyageai": "^0.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
